generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  sk
  en
}

enum ClientType {
  company
  person
}

enum Unit {
  h
  day
  pcs
  pkg
}

enum SnippetType {
  intro
  terms
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  invoiced
}

enum TotalDiscountType {
  none
  pct
  amount
}

model Settings {
  id               Int      @id @default(1)
  companyName      String   @map("company_name")
  companyAddress   String   @map("company_address")
  companyIco       String?  @map("company_ico")
  companyDic       String?  @map("company_dic")
  companyIcdph     String?  @map("company_icdph")
  companyEmail     String   @map("company_email")
  companyPhone     String   @map("company_phone")
  companyWebsite   String?  @map("company_website")
  logoUrl          String?  @map("logo_url")
  defaultLanguage  Language @default(sk) @map("default_language")
  defaultCurrency  String   @default("EUR") @map("default_currency")
  vatRate          Decimal  @default(20) @map("vat_rate")
  numberingYear    Int      @map("numbering_year")
  numberingCounter Int      @default(0) @map("numbering_counter")

  @@map("settings")
}

model Client {
  id                  String     @id @default(cuid())
  type                ClientType
  name                String
  billingAddressLine1 String     @map("billing_address_line1")
  billingAddressLine2 String?    @map("billing_address_line2")
  city                String
  zip                 String
  country             String
  ico                 String?
  dic                 String?
  icdph               String?
  contactName         String     @map("contact_name")
  contactEmail        String     @map("contact_email")
  contactPhone        String?    @map("contact_phone")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  quotes              Quote[]

  @@index([name])
  @@map("clients")
}

model CatalogItem {
  id               String   @id @default(cuid())
  category         String
  tags             Json
  name             String
  description      String?
  defaultUnit      Unit     @map("default_unit")
  defaultUnitPrice Decimal  @map("default_unit_price")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([name])
  @@map("catalog_items")
}

model Snippet {
  id             String     @id @default(cuid())
  type           SnippetType
  language       Language
  title          String
  contentMarkdown String    @map("content_markdown")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([type, language])
  @@map("snippets")
}

model Quote {
  id                  String            @id @default(cuid())
  number              String            @unique
  title               String
  status              QuoteStatus       @default(draft)
  clientId            String            @map("client_id")
  language            Language
  currency            String
  validUntil          DateTime          @map("valid_until")
  vatEnabled          Boolean           @default(true) @map("vat_enabled")
  vatRate             Decimal           @map("vat_rate")
  showClientDetailsInPdf Boolean        @default(true) @map("show_client_details_in_pdf")
  showCompanyDetailsInPdf Boolean       @default(true) @map("show_company_details_in_pdf")
  introContentMarkdown String           @default("") @map("intro_content_markdown")
  termsContentMarkdown String           @default("") @map("terms_content_markdown")
  revisionsIncluded   Int               @default(1) @map("revisions_included")
  totalDiscountType   TotalDiscountType @default(none) @map("total_discount_type")
  totalDiscountValue  Decimal           @default(0) @map("total_discount_value")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  client      Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  items       QuoteItem[]
  scopeItems  ScopeItem[]
  versions    QuoteVersion[]

  @@index([status])
  @@index([clientId])
  @@index([currency])
  @@index([createdAt])
  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String   @map("quote_id")
  name        String
  description String?
  unit        Unit
  qty         Decimal
  unitPrice   Decimal  @map("unit_price")
  discountPct Decimal  @default(0) @map("discount_pct")
  sortOrder   Int      @map("sort_order")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
  @@map("quote_items")
}

model ScopeItem {
  id          String   @id @default(cuid())
  quoteId     String   @map("quote_id")
  category    String
  itemKey     String   @map("item_key")
  label       String
  description String?
  sortOrder   Int      @map("sort_order")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, category])
  @@index([quoteId, sortOrder])
  @@map("scope_items")
}

model QuoteVersion {
  id            String   @id @default(cuid())
  quoteId       String   @map("quote_id")
  versionNumber Int      @map("version_number")
  exportedAt    DateTime @default(now()) @map("exported_at")
  snapshotJson  Json     @map("snapshot_json")
  pdfFileUrl    String   @map("pdf_file_url")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, versionNumber])
  @@index([quoteId])
  @@map("quote_versions")
}
